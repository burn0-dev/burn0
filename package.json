{
  "name": "@burn0/burn0",
  "version": "0.2.2",
  "description": "Lightweight cost observability for every API call in your stack",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "bin": {
    "burn0": "./dist/cli/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "import": "./dist/index.mjs"
    },
    "./register": {
      "require": "./dist/register.js",
      "import": "./dist/register.mjs"
    },
    "./track": {
      "types": "./dist/track.d.ts",
      "require": "./dist/track.js",
      "import": "./dist/track.mjs"
    }
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.mjs",
    "dist/**/*.d.ts",
    "dist/**/*.d.mts",
    "scripts"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build",
    "postinstall": "node scripts/postinstall.js || true"
  },
  "keywords": [
    "cost",
    "observability",
    "llm",
    "api",
    "tracking",
    "openai",
    "anthropic",
    "burn-rate",
    "cost-tracking",
    "api-costs"
  ],
  "author": "burn0",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/burn0-dev/burn0.git"
  },
  "homepage": "https://burn0.dev",
  "bugs": {
    "url": "https://github.com/burn0-dev/burn0/issues"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "tsup": "^8.0.0",
    "vitest": "^3.0.0",
    "@types/node": "^22.0.0"
  },
  "dependencies": {
    "commander": "^13.0.0",
    "@inquirer/prompts": "^7.0.0",
    "chalk": "^5.4.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
